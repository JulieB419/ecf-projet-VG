# Vite & Gourmand — configuration locale (NE PAS VERSIONNER .env)
# Copiez ce fichier en .env puis renseignez vos valeurs locales.

APP_ENV=production
APP_DEBUG=0
APP_URL=https://example.com

# --- MySQL / MariaDB ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vite_gourmand
DB_USER=root
DB_PASS=

# --- Email (PHPMailer) ---
# En dev, vous pouvez laisser vide et désactiver l’envoi, ou renseigner un SMTP de test (Mailtrap, etc.)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Vite & Gourmand"

# --- MongoDB (statistiques admin) ---
# Optionnel en local : si vide, la page stats peut être désactivée/grisée.
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=vite_gourmand_stats
